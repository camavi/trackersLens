{
  "manifest_version": 3,
  "name": "Trackers Lens",
  "version": "1.0",
  "description": "Trackers Lens",
  "permissions": ["storage", "activeTab", "scripting", "notifications"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/logo16.png",
      "48": "icons/logo48.png",
      "128": "icons/logo128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "js/background.js"
  },
  "icons": {
    "16": "icons/logo16.png",
    "48": "icons/logo48.png",
    "128": "icons/logo128.png"
  }
}
